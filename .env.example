# Copie este arquivo para .env e preencha com seus dados.
# Use uma SENHA DE APP do Gmail (conta com 2FA ativo), não a senha normal.
# Gerar em: https://myaccount.google.com/apppasswords
GMAIL_USER=seu_email@gmail.com
GMAIL_APP_PASSWORD=sua_senha_de_app_aqui

# URL pública do site (usada no link do e-mail de notificação)
SITE_URL=http://localhost:3000
